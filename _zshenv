# Modern environment configuration

# XDG Base Directory specification
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_STATE_HOME="$HOME/.local/state"

# Editor and pager
export EDITOR="nvim"
export VISUAL="nvim"
export PAGER="less"
export MANPAGER="sh -c 'col -bx | bat -l man -p'"

# Language settings
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

# Path configuration (add to beginning for priority)
typeset -U path  # Keep unique entries only
path=(
    "$HOME/.atuin/bin"
    "$HOME/.local/bin"
    "$HOME/bin"
    "/usr/local/bin"
    $path
)

# Go configuration
if command -v go >/dev/null 2>&1; then
    export GOPATH="$HOME/go"
    export GOBIN="$GOPATH/bin"
    path=("$GOBIN" $path)
fi

# Rust configuration
if [ -d "$HOME/.cargo" ]; then
    path=("$HOME/.cargo/bin" $path)
fi

# Python configuration
if [ -d "$HOME/.pyenv" ]; then
    export PYENV_ROOT="$HOME/.pyenv"
    path=("$PYENV_ROOT/bin" $path)
    eval "$(pyenv init --path)"
fi

# Node.js configuration
export NVM_DIR="$HOME/.nvm"

# Google Cloud SDK (check common installation paths)
for gcloud_path in \
    "$HOME/google-cloud-sdk" \
    "/opt/google-cloud-sdk" \
    "/usr/local/google-cloud-sdk" \
    "/snap/google-cloud-sdk/current"
do
    if [ -d "$gcloud_path" ]; then
        path=("$gcloud_path/bin" $path)
        break
    fi
done

# Snap packages
if [ -d "/snap/bin" ]; then
    path=("/snap/bin" $path)
fi

# Starship prompt configuration
export STARSHIP_CONFIG="$HOME/.config/starship.toml"

# FZF configuration
export FZF_DEFAULT_OPTS="--height 40% --layout=reverse --border --ansi"

# Less configuration
export LESS="-R -M --shift 5"
export LESSHISTFILE="-"

# History configuration
export HISTCONTROL="ignoreboth:erasedups"
export HISTSIZE=50000
export HISTFILESIZE=50000

# Development tools
export DOCKER_BUILDKIT=1
export COMPOSE_DOCKER_CLI_BUILD=1

# GPG configuration
export GPG_TTY=$(tty)

# Clean up duplicates and export
export PATH
